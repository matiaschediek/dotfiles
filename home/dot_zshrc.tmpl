#!/usr/bin/env zsh

# ─── ZSH OPTIONS ──────────────────────────────────────────────────────────────
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FCNTL_LOCK
setopt +o nomatch

# ─── HOMEBREW ─────────────────────────────────────────────────────────────────
export HOMEBREW_PREFIX="{{ .homebrew_prefix }}"
export PATH="$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$PATH"

# ─── BASE PATH ────────────────────────────────────────────────────────────────
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

# ─── RUST ─────────────────────────────────────────────────────────────────────
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"
export PATH="$HOME/.cargo/bin:$PATH"

# ─── GO ───────────────────────────────────────────────────────────────────────
export GOPATH="$HOME/.go"
export PATH="$PATH:$GOPATH/bin"

# ─── PYENV ────────────────────────────────────────────────────────────────────
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv &>/dev/null; then
  eval "$(pyenv init -)"
fi

# ─── FNM (Node.js) ────────────────────────────────────────────────────────────
if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# ─── PNPM ─────────────────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
export PNPM_HOME="$HOME/Library/pnpm"
{{ else -}}
export PNPM_HOME="$HOME/.local/share/pnpm"
{{ end -}}
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# ─── RUBY ─────────────────────────────────────────────────────────────────────
export GEM_HOME="$HOME/.gem"
export PATH="$GEM_HOME/bin:$PATH"
{{ if eq .chezmoi.os "darwin" -}}
export PATH="$HOMEBREW_PREFIX/opt/ruby/bin:$PATH"
{{ end -}}

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
export ANTHROPIC_MODEL="claude-sonnet-4-6[1m]"

# ─── FZF ──────────────────────────────────────────────────────────────────────
export FZF_DEFAULT_OPTS="--color=pointer:#ebdbb2,bg+:#3c3836,fg:#ebdbb2,fg+:#fbf1c7,hl:#8ec07c,info:#928374,header:#fb4934 --reverse"
[[ -f "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh" ]] && \
  source "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
[[ -f "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh" ]] && \
  source "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh"

# ─── ZSH PLUGINS ──────────────────────────────────────────────────────────────
ZSH_AUTOSUGGEST_USE_ASYNC=true
[[ -f "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && \
  source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"

ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)
ZSH_HIGHLIGHT_MAXLENGTH=300
[[ -f "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] && \
  source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# ─── STARSHIP PROMPT ──────────────────────────────────────────────────────────
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi

# ─── ATUIN (history) ──────────────────────────────────────────────────────────
[[ -f "$HOME/.atuin/bin/env" ]] && . "$HOME/.atuin/bin/env"
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

# ─── ZOXIDE (navigation) ──────────────────────────────────────────────────────
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi
alias j="z"

# ─── COLIMA (Docker) ──────────────────────────────────────────────────────────
if command -v colima &>/dev/null && ! colima status &>/dev/null; then
  colima start
fi

# ─── ALIASES — ls ─────────────────────────────────────────────────────────────
alias ls='lsd'
alias ll='lsd -l'
alias la='lsd -a'
alias lla='lsd -la'
alias lt='lsd --tree'

# ─── ALIASES — navigation ─────────────────────────────────────────────────────
alias sudo='sudo '
alias ..="cd .."
alias ...="cd ../.."
alias ~="cd ~"
alias dotfiles='cd ~/dotfiles'

# ─── ALIASES — git ────────────────────────────────────────────────────────────
alias gaa="git add -A"
alias gc="git commit"
alias gca="git add --all && git commit --amend --no-edit"
alias gco="git checkout"
alias gd="git diff"
alias gs="git status -sb"
alias gf="git fetch --all -p"
alias gps="git push"
alias gpsf="git push --force"
alias gpl="git pull --rebase --autostash"
alias gb="git branch"
alias gl="git log --oneline --graph --decorate"

# ─── ALIASES — utils ──────────────────────────────────────────────────────────
alias k='kill -9'
alias o.='open .'
{{ if eq .chezmoi.os "darwin" -}}
alias c.='(code $PWD &>/dev/null &)'
{{ end -}}

# ─── ALIASES — atuin ──────────────────────────────────────────────────────────
atsearch() { atuin search "$1" --format "{host}\t{command}"; }
alias h="atsearch"
alias hh="atuin search -i"

# ─── FUNCTIONS ────────────────────────────────────────────────────────────────
function cdd() {
  cd "$(ls -d -- */ | fzf)" || echo "Invalid directory"
}

function recent_dirs() {
  local escaped_home selected
  escaped_home=$(echo $HOME | sed 's/\//\\\//g')
  selected=$(dirs -p | sort -u | fzf)
  cd "$(echo "$selected" | sed "s/\~/$escaped_home/")" || echo "Invalid directory"
}

# ─── SDKMAN (Java) — must be last ─────────────────────────────────────────────
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

# ─── GIT-AI ───────────────────────────────────────────────────────────────────
export PATH="$HOME/.git-ai/bin:$PATH"
zstyle ':completion:*' menu select

# ─── WORK OVERLAY ─────────────────────────────────────────────────────────────
[[ -f "$HOME/.zshrc.work" ]] && source "$HOME/.zshrc.work"
